"""
rmath.constants — named mathematical and machine-precision constants.
Maintain this file: stubs/rmath/constants.pyi
"""

PI: float            # 3.14159265358979…
TAU: float           # 2π = 6.28318…
E: float             # Euler's number = 2.71828…
PHI: float           # Golden ratio = 1.61803…
SQRT_2: float        # √2
SQRT_3: float        # √3
SQRT_5: float        # √5
SQRT_1_2: float      # 1/√2
LN_2: float          # ln(2) = 0.69314…
LN_10: float         # ln(10) = 2.30258…
LOG2_E: float        # log₂(e) = 1.44269…
LOG10_E: float       # log₁₀(e) = 0.43429…
EPSILON_F32: float   # machine epsilon for f32 (~1.19e-7)
EPSILON_F64: float   # machine epsilon for f64 (~2.22e-16)
MAX_F32: float       # maximum representable f32
MAX_F64: float       # maximum representable f64
MIN_POSITIVE_F64: float   # smallest positive f64
INF: float           # positive infinity
NEG_INF: float       # negative infinity
NAN: float           # not-a-number
