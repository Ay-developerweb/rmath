def pop_variance(v: Vector) -> float: ...
def std_dev(v: Vector) -> float: ...
def pop_std_dev(v: Vector) -> float: ...
def median(v: Vector) -> float: ...
def percentile(v: Vector, q: float) -> float: ...
def vmin(v: Vector) -> float: ...
def vmax(v: Vector) -> float: ...
def argmin(v: Vector) -> int: ...
def argmax(v: Vector) -> int: ...
def norm(v: Vector) -> float: ...
