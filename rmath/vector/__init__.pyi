def isnan(v: Vector)     -> List[bool]: ...
def isfinite(v: Vector)  -> List[bool]: ...
def isinf(v: Vector)     -> List[bool]: ...
def is_integer(v: Vector)-> List[bool]: ...
def is_prime(v: Vector)  -> List[bool]: ...
